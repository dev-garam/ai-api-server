# Runtime
NODE_ENV=local
PORT=3000
LOG_LEVEL=debug
TZ=Asia/Seoul

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_api_server?schema=public

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=ai-api-server

# Internal Auth (Lite)
INTERNAL_API_KEY=change-me
JWT_SECRET=change-me
JWT_ISSUER=ai-api-server
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Agent Server Bridge (Required)
AGENT_SERVER_HOST=http://localhost:4000
AGENT_PING_PATH=/api/v1/ping
AGENT_INTENT_DETECT_PATH=/api/v1/intent/detect

# Optional
REQUEST_TIMEOUT_MS=30000
