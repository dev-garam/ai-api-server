# Runtime
NODE_ENV=local
PORT=8888
LOG_LEVEL=debug
TZ=Asia/Seoul

# Database
DATABASE_URL=postgresql://ai_module:ai_module@localhost:5432/ai_module?schema=public

# Redis
REDIS_URL=redis://ai_module:ai_module@localhost:6379/1
REDIS_PREFIX=ai-module

# Internal Auth (Lite)
INTERNAL_API_KEY=change-me
JWT_SECRET=change-me
JWT_ISSUER=ai-module
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
HMAC_MAX_SKEW_SECONDS=60
LOCAL_AUTH_BYPASS=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Agent Server Bridge (Required)
AGENT_SERVER_HOST=http://localhost:8889
AGENT_PING_PATH=/api/v1/ping
AGENT_INTENT_DETECT_PATH=/api/v1/intent/detect
AGENT_CHAT_REPLY_PATH=/api/v1/chat/reply
AGENT_DEFAULT_MODEL=google-genai:gemini-2.5-flash-lite
AGENT_HMAC_ENABLED=true
AGENT_HMAC_KEY_ID=agent-local-key
AGENT_HMAC_SECRET=change-me-agent-hmac-secret

# Optional
REQUEST_TIMEOUT_MS=30000
